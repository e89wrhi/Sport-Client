# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=super-secret-value
AUTH_SECRET=super-secret-value

# Mock Authentication (set to true for development without Duende IdentityServer)
USE_MOCK_AUTH=true
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Duende IdentityServer Configuration (only needed when USE_MOCK_AUTH=false)
AUTH_DUENDE_ISSUER=https://localhost:5001
AUTH_DUENDE_ID=admin-portal
AUTH_DUENDE_SECRET=admin-portal-secret

# Google Authentication
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Required Role for admin Portal
REQUIRED_ROLE=admin

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=https://localhost:7001
